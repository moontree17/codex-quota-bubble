{
  "name": "codex-quota-bubble",
  "version": "0.1.5",
  "description": "Minimal Codex quota bubble for Windows.",
  "main": "src/main/main.js",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable"
  },
  "build": {
    "appId": "local.codex.quota.bubble",
    "productName": "Codex Quota Bubble",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Codex-Quota-Bubble-${version}-win-x64.exe"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
